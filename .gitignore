# ── Secrets / local config (never commit real keys) ───────────────────────────
# Frontend: copy .env.template → .env ; app.json.template → app.json
frontend/.env
frontend/.env.*
!frontend/.env.template
frontend/app.json

# Backend: use application-local.yml for DB/JWT/Google overrides (optional)
backend/src/main/resources/application-local.yml

# Google / Firebase mobile client files (if you add them later)
**/google-services.json
**/GoogleService-Info.plist

# Service account JSON (server-side Google APIs)
**/*service-account*.json
**/credentials.json

# Android signing
*.jks
*.keystore

# Accidental Windows env-expansion artifact
frontend/%ProgramData%/

# ── Backend build output ─────────────────────────────────────────────────────
backend/target/
*.class
*.jar
*.war
*.nar
*.ear
hs_err_pid*
replay_pid*

# ── Frontend / Node ───────────────────────────────────────────────────────────
frontend/node_modules/
frontend/.expo/
frontend/dist/

# ── Logs ───────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*

# ── OS / IDE ───────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
*.iml
.vscode/settings.json

# ── Misc Java ──────────────────────────────────────────────────────────────────
.mtj.tmp/
*.ctxt
*.zip
*.tar.gz
*.rar
